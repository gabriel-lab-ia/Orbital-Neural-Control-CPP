# Copy to .env only if you need local secrets for future integrations.
# Keep real credentials out of source code.

APP_ENV=local
LOG_LEVEL=info

# Persistence
# SQLite is the default local/dev backend.
DB_BACKEND=sqlite
SQLITE_PATH=artifacts/experiments.sqlite

# PostgreSQL is optional for production-like local testing and deployments.
# Do not commit real credentials; set them in your shell, secret manager, or orchestration platform.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orbital
POSTGRES_USER=orbital
POSTGRES_PASSWORD=replace-me
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
POSTGRES_STATEMENT_TIMEOUT_MS=5000

# Optional FastAPI serving layer
ORBITAL_CPP_CONTROL_ENDPOINT=
